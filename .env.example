# Copy this file to `.env` and fill in the values.

NODE_ENV=development
PORT=8000

# PostgreSQL connection string
DATABASE_URL=postgresql://USER@localhost:5432/irate_db?schema=public

# Redis connection string
REDIS_URL=redis://127.0.0.1:6379

# Auth secrets — generate strong random values in production:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too

# Optional log level: trace | debug | info | warn | error
# LOG_LEVEL=debug

# Seed data (used by `npm run seed`)
SEED_ADMIN_EMAIL=admin@irate.dev
SEED_ADMIN_PASSWORD=Admin123!
SEED_USER_PASSWORD=Password123!
