generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  kyc       KYC?
  wallets   Wallet[]
}

model KYC {
  id          String    @id @default(cuid())
  userId      String    @unique
  fullName    String
  dateOfBirth DateTime
  address     String
  idType      String
  idNumber    String
  documentUrl String?
  status      KYCStatus @default(PENDING)
  verifiedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
}

model Wallet {
  // balance is stored in MINOR UNITS (e.g. kobo / cents). See README "Money".
  // accountNumber is the 10-digit number users share to receive money.
  id            String        @id @default(cuid())
  userId        String
  accountNumber String        @unique
  balance       BigInt        @default(0)
  createdAt     DateTime      @default(now())
  Ledger        Ledger[]
  Transaction   Transaction[]
  user          User          @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Transaction {
  id        String          @id @default(cuid())
  walletId  String
  type      TransactionType
  amount    BigInt // minor units
  createdAt DateTime        @default(now())
  wallet    Wallet          @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
  @@index([type, createdAt])
}

model Ledger {
  id            String     @id @default(cuid())
  walletId      String
  referenceId   String?
  description   String
  amount        BigInt // minor units
  balanceBefore BigInt // minor units
  balanceAfter  BigInt // minor units
  type          LedgerType
  createdAt     DateTime   @default(now())
  wallet        Wallet     @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  USER
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum LedgerType {
  CREDIT
  DEBIT
  FEE
  ADJUSTMENT
}

enum KYCStatus {
  PENDING
  VERIFIED
  REJECTED
}
